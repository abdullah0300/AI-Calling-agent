# Supabase — infrastructure, required to boot
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server
PORT=4000

# NOTE: All provider API keys are managed via the Settings page in the dashboard
# and loaded from the database at call start. You do NOT need to set them here.
#
# Optional fallback env vars (used only if the DB setting row is empty):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPGRAM_API_KEY=
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# TELNYX_API_KEY=
# TELNYX_CONNECTION_ID=
