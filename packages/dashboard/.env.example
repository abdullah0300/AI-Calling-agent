# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telephony
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ACTIVE_TELEPHONY=telnyx

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
WS_SERVER_URL=http://localhost:4000
# Public HTTPS URL of the ws-server (ngrok URL in local dev, Cloud Run URL in prod)
# Telnyx uses this for webhook callbacks and WebSocket audio streaming
# Example: https://your-ngrok-id.ngrok-free.app
WS_PUBLIC_URL=
WEBHOOK_SECRET=your_random_secret_here
