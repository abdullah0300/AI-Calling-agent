# Supabase — infrastructure, required to boot
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
WS_SERVER_URL=http://localhost:4000
# WS_PUBLIC_URL is the ngrok/public HTTPS URL of the ws-server
# Used so Telnyx can reach the WebSocket and webhook endpoints
WS_PUBLIC_URL=https://your-ngrok-url.ngrok.io

# NOTE: API keys (Telnyx, Deepgram, ElevenLabs, Anthropic, OpenAI) are
# managed via the Settings page in the dashboard and stored in the database.
# Do NOT add them here. If you need a temporary fallback during migration,
# the ws-server .env.example shows the supported variable names.
